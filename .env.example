# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# サーバーポート（Railway/Renderは自動設定）
PORT=3001

# 本番環境フラグ（Railway/Renderでは production に設定）
NODE_ENV=production

# kabu+ API（auカブコム証券 MarketSpeed II）
KABUCOM_API_PASSWORD=
KABU_API_BASE=http://localhost:18080

# LINE Messaging API（損切/利確アラート通知）
# 取得方法: https://developers.line.biz/console/ でMessaging APIチャネル作成
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# SQLite データベースパス（省略時: holdings.db）
DB_PATH=holdings.db
